<?xml version="1.0" encoding="utf-8"?>
<!-- File: res/drawable/switch_track_ios.xml -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- State saat switch dalam keadaan ON (tercentang) -->
    <item android:state_checked="true">
        <shape android:shape="rectangle">
            <!-- Warna hijau khas iOS saat ON -->
            <solid android:color="@color/colorPrimary" />
            <!-- Membuat sudut menjadi sangat bulat seperti kapsul -->
            <corners android:radius="100dp" />
            <size android:height="24dp" />
        </shape>
    </item>

    <!-- State saat switch dalam keadaan OFF (tidak tercentang) -->
    <item android:state_checked="false">
        <shape android:shape="rectangle">
            <!-- Warna abu-abu khas iOS saat OFF -->
            <solid android:color="#E9E9EA" />
            <corners android:radius="200dp" />
            <size android:height="24dp" />
            <!-- Memberi sedikit garis tepi agar terlihat jelas -->
            <stroke android:width="1dp" android:color="#D1D1D6" />
        </shape>
    </item>

</selector>
