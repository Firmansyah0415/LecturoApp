<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.LecturoApp" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorOnPrimary">@color/colorOnPrimary</item>
        <item name="colorPrimaryContainer">@color/colorPrimaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/colorOnPrimaryContainer</item>

        <item name="colorSecondary">@color/colorSecondary</item>
        <item name="colorOnSecondary">@color/colorOnSecondary</item>
        <item name="colorSecondaryContainer">@color/colorSecondaryContainer</item>
        <item name="colorOnSecondaryContainer">@color/colorOnSecondaryContainer</item>

        <item name="android:colorBackground">@color/colorBackground</item>
        <item name="colorOnBackground">@color/text_primary</item>

        <item name="colorSurface">@color/colorSurface</item>
        <item name="colorOnSurface">@color/text_primary</item>

        <item name="android:statusBarColor">@color/text_primary</item>
        <item name="android:windowLightStatusBar">true</item> </style>

    <style name="Theme.LecturoApp" parent="Base.Theme.LecturoApp" />

    <style name="ShapeAppearance.App.LargeComponent" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamilyBottomLeft">rounded</item>
        <item name="cornerSizeBottomLeft">16dp</item>
        <item name="cornerFamilyBottomRight">rounded</item>
        <item name="cornerSizeBottomRight">16dp</item>
    </style>

    <style name="DayLabel">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textAppearance">@style/TextAppearance.Material3.BodySmall</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!--  Text Input Layout Style  -->
    <style name="Widget.App.TextInputLayout.Rounded" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">16dp</item>
        <item name="boxCornerRadiusTopEnd">16dp</item>
        <item name="boxCornerRadiusBottomStart">16dp</item>
        <item name="boxCornerRadiusBottomEnd">16dp</item>
    </style>

    <style name="ThemeOverlay.App.TextInput.Task" parent="">
        <item name="colorPrimary">@color/task_color</item>
        <item name="colorControlActivated">@color/task_color</item>
    </style>

    <style name="ThemeOverlay.App.TextInput.Teaching" parent="">
        <item name="colorPrimary">@color/teaching_color</item>
        <item name="colorControlActivated">@color/teaching_color</item>
    </style>

    <style name="ThemeOverlay.App.TextInput.Event" parent="">
        <item name="colorPrimary">@color/event_color</item>
        <item name="colorControlActivated">@color/event_color</item>
    </style>

    <style name="ThemeOverlay.App.TextInput.Consultation" parent="">
        <item name="colorPrimary">@color/consultation_color</item>
        <item name="colorControlActivated">@color/consultation_color</item>
    </style>
    <!--  End Text Input Layout Style  -->

    <!--  Switch button Consultation Style  -->
    <style name="ThemeOverlay.App.Switch.Consultation" parent="">
        <item name="colorPrimary">@color/consultation_color</item>
        <item name="colorOnPrimary">@color/white</item>
    </style>

    <!--  Switch button Consultation Style  -->
    <style name="ThemeOverlay.App.Switch.Lecturo" parent="">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorOnPrimary">@color/white</item>
    </style>

    <!--  Custom Bottom Nav Indicator  -->
    <style name="CustomBottomNavIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/colorPrimaryContainer</item>
    </style>

</resources>