<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="52dp"
    android:layout_margin="1dp">

    <!-- Day Background -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardDayBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Day Number -->
            <TextView
                android:id="@+id/tvDayNumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="?attr/colorOnSurface"
                android:textStyle="bold"
                tools:text="15" />

            <!-- Schedule Indicators -->
            <LinearLayout
                android:id="@+id/layoutIndicators"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:layout_marginBottom="5dp"
                android:gravity="center"
                android:orientation="horizontal">

                <!-- Indikator-indikator ini TIDAK diubah agar warnanya tetap spesifik -->
                <View
                    android:id="@+id/indicatorTask"
                    android:layout_width="5dp"
                    android:layout_height="5dp"
                    android:layout_marginEnd="2dp"
                    android:background="@drawable/circle_task"
                    android:visibility="gone"
                    tools:visibility="visible"/>

                <View
                    android:id="@+id/indicatorTeaching"
                    android:layout_width="5dp"
                    android:layout_height="5dp"
                    android:layout_marginEnd="2dp"
                    android:background="@drawable/circle_teaching"
                    android:visibility="gone"
                    tools:visibility="visible"/>

                <View
                    android:id="@+id/indicatorEvent"
                    android:layout_width="5dp"
                    android:layout_height="5dp"
                    android:layout_marginEnd="2dp"
                    android:background="@drawable/circle_event"
                    android:visibility="gone"
                    tools:visibility="visible"/>

                <View
                    android:id="@+id/indicatorConsultation"
                    android:layout_width="5dp"
                    android:layout_height="5dp"
                    android:background="@drawable/circle_consultation"
                    android:visibility="gone"
                    tools:visibility="visible"/>

            </LinearLayout>

        </RelativeLayout>

    </com.google.android.material.card.MaterialCardView>

</FrameLayout>
